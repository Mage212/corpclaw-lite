FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Add non-root user
RUN useradd -m -d /home/agent -s /bin/bash agent

# Set up workdirs
RUN mkdir -p /workspace /config && \
    chown -R agent:agent /workspace /config

WORKDIR /home/agent

# Install Python packages commonly used by agents
RUN pip install --no-cache-dir \
    pandas \
    openpyxl \
    python-docx \
    requests \
    beautifulsoup4 \
    pyyaml

# Install corpclaw_lite package (needed for agent_worker + IPC auth)
COPY pyproject.toml README.md ./
COPY src/ src/
RUN pip install --no-cache-dir .

USER agent

ENV PYTHONUNBUFFERED=1

# Keep container alive for IPC via `docker exec`
CMD ["tail", "-f", "/dev/null"]
