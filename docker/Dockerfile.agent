FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Add non-root user
RUN useradd -m -d /home/agent -s /bin/bash agent

# Set up workdirs
RUN mkdir -p /workspace /config && \
    chown -R agent:agent /workspace /config

WORKDIR /home/agent

# Install Python packages commonly used by agents
# This allows quick execution of data science / file tools
RUN pip install --no-cache-dir \
    pandas \
    openpyxl \
    python-docx \
    requests \
    beautifulsoup4 \
    pyyaml

USER agent
# Start an infinite loop to keep container alive for IPC
CMD ["tail", "-f", "/dev/null"]
