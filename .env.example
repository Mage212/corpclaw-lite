# CorpClaw Lite — Environment Variables
#
# Copy to .env and fill in your values.

# ==========================================
# 🔒 SECURITY
# ==========================================
# REQUIRED: HMAC key for container IPC (min 32 chars, random)
CORPCLAW_IPC_SECRET="your-random-secret-key-at-least-32-characters-long"

# ==========================================
# 🤖 CHATBOT & CHANNELS
# ==========================================
# REQUIRED (for Telegram bot): Your Telegram Bot API token from BotFather
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ==========================================
# 🧠 LLM PROVIDERS
# ==========================================
# Register providers using PROVIDER_{NAME}__{FIELD} pattern.
# Fields: TYPE (openai|anthropic), BASE_URL, API_KEY
#
# TYPE=openai supports: Ollama, vLLM, LM Studio, OpenRouter, llama.cpp, Groq, etc.
# TYPE=anthropic supports: Anthropic Claude API (and proxies/gateways)
#
# At least one provider is required. Add as many as you need.

# 1. Direct llama.cpp server (default for slot-affinity)
PROVIDER_LLAMACPP__TYPE=openai
PROVIDER_LLAMACPP__BASE_URL="http://localhost:8080/v1"
PROVIDER_LLAMACPP__API_KEY="llamacpp"

# 2. Local Ollama (optional)
# PROVIDER_OLLAMA__TYPE=openai
# PROVIDER_OLLAMA__BASE_URL="http://localhost:11434/v1"
# PROVIDER_OLLAMA__API_KEY="ollama"

# 3. Local LM Studio (optional)
# PROVIDER_LMSTUDIO__TYPE=openai
# PROVIDER_LMSTUDIO__BASE_URL="http://localhost:1234/v1"

# 4. OpenRouter (optional — access to many cloud models)
# PROVIDER_OPENROUTER__TYPE=openai
# PROVIDER_OPENROUTER__BASE_URL="https://openrouter.ai/api/v1"
# PROVIDER_OPENROUTER__API_KEY="sk-or-..."

# 5. Anthropic Claude (optional)
# PROVIDER_ANTHROPIC__TYPE=anthropic
# PROVIDER_ANTHROPIC__API_KEY="sk-ant-..."
# PROVIDER_ANTHROPIC__BASE_URL="https://api.anthropic.com"

# 6. Groq (optional)
# PROVIDER_GROQ__TYPE=openai
# PROVIDER_GROQ__BASE_URL="https://api.groq.com/openai/v1"
# PROVIDER_GROQ__API_KEY="gsk_..."

# 7. vLLM (optional)
# PROVIDER_VLLM__TYPE=openai
# PROVIDER_VLLM__BASE_URL="http://localhost:8000/v1"
