# CorpClaw Lite - Environment Configuration
# Copy this file to .env and fill in your values.
# uv run will automatically load variables from .env

# ==========================================
# 🔐 CRITICAL SECURITY SECRETS
# ==========================================
# REQUIRED: Secret key for IPC authentication between host and Docker containers.
# Generate a secure random string (e.g. `openssl rand -hex 32`)
CORPCLAW_IPC_SECRET="replace-this-with-a-secure-random-string"

# ==========================================
# 🤖 CHATBOT & CHANNELS
# ==========================================
# REQUIRED (for Telegram bot): Your Telegram Bot API token from BotFather
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ==========================================
# 🧠 LLM PROVIDERS 
# ==========================================
# 1. Local execution via Ollama (Default)
OPENAI_BASE_URL="http://localhost:11434/v1"
OPENAI_MODEL="qwen2.5:7b"
# OPENAI_API_KEY="" # Usually not required for local Ollama/LM Studio

# 2. Anthropic (Optional)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
# ANTHROPIC_BASE_URL="https://api.anthropic.com" # Change if using a proxy/gateway

# ==========================================
# ⚙️ PYDANTIC SETTINGS OVERRIDES (Optional)
# ==========================================
# You can override nested Pydantic settings using the __ delimiter.
# Example: change the default LLM provider routing from local to anthropic
# LLM__DEFAULT="anthropic"

# Example: override Telegram rate limit
# TELEGRAM__RATE_LIMIT_PER_MINUTE="20"

# Example: override Container Max Memory
# CONTAINER__MAX_MEMORY="1g"

# ==========================================
# 📁 PATH SETTINGS (Optional)
# ==========================================
# CORPCLAW_ROOT="/path/to/corpclaw-lite"
# CORPCLAW_DATA_DIR="/path/to/corpclaw-lite/data"
